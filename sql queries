-- data cleaning
CREATE OR REPLACE VIEW v_cleaned_texas_jobs AS
SELECT 
    
    INITCAP(REPLACE(REPLACE(job_title, '(USA)', ''), '-', '')) AS display_title,
    company,
    location,
    category,
    
    CASE 
        WHEN level IN ('Senior Level', 'Management') OR job_title ILIKE '%Senior%' OR job_title ILIKE '%Lead%' THEN 'Senior'
        WHEN level = 'Entry Level' OR job_title ILIKE '%Junior%' OR job_title ILIKE '%Entry%' THEN 'Junior/Entry'
        WHEN level = 'Internship' THEN 'Internship'
        ELSE 'Mid-Level'
    END AS seniority_level,
   
    CAST(LEFT(date_posted, 10) AS DATE) AS post_date
FROM raw_jobs

WHERE category IN ('Data and Analytics', 'Software Engineering')
AND job_title NOT ILIKE '%Meat%' 
AND job_title NOT ILIKE '%Produce%'
AND job_title NOT ILIKE '%Retail%';
