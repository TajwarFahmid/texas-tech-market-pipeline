-- creating table
CREATE TABLE raw_jobs (
    job_title TEXT,
    company TEXT,
    location TEXT,
    category TEXT,
    level TEXT,
    date_posted TEXT
);

-- creating the salary table
CREATE TABLE salary_benchmarks (
    category TEXT,
    seniority_level TEXT,
    avg_annual_salary INT
);

